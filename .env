# ============================================
# Dropshipping AI Research Agent - API Keys
# ============================================
# Bu dosyayı .env olarak kopyalayın:
#   cp .env.example .env
# Ardından kendi API key'lerinizi girin.

# ── Google Gemini AI (Ücretsiz) ──────────────
# https://aistudio.google.com/apikey
GOOGLE_GEMINI_API_KEY=AQ.Ab8RN6In_Rn1yflTiINYXsN2xm-jrxFjkmWBS_sR4MCGUkj00w

# ── OpenAI GPT-4o (Ücretli) ─────────────────
# https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ── Anthropic Claude (Ücretli) ───────────────
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Tavily Web Arama (1000 ücretsiz/ay) ──────
# https://tavily.com
TAVILY_API_KEY=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

# ── Reddit API (Ücretsiz) ────────────────────
# https://www.reddit.com/prefs/apps → "script" app oluşturun
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USER_AGENT=DropshippingResearchAgent/1.0

# ── YouTube Data API (Ücretsiz, günlük kota) ─
# https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your_youtube_api_key_here

# ── eBay Developer API (OAuth2) ──────────────
# https://developer.ebay.com/my/keys
# 1. developer.ebay.com'da ücretsiz hesap açın
# 2. "Application Keys" oluşturun
# 3. Aşağıya kopyalayın
EBAY_APP_ID=your_ebay_app_id_here
EBAY_CERT_ID=your_ebay_cert_id_here
EBAY_DEV_ID=your_ebay_dev_id_here
EBAY_REDIRECT_URI=http://localhost:8000/api/ebay/oauth/callback

# ── Sunucu Ayarları ───────────────────────────
HOST=0.0.0.0
PORT=8000
